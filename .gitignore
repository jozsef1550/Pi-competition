## .NET / C# gitignore

# Build output
bin/
obj/

# Visual Studio / Rider
.vs/
.idea/
*.user
*.suo
*.userprefs
*.lock.json

# NuGet
*.nupkg
packages/
*.nuget.props
*.nuget.targets

# Test results
TestResults/
*.trx
*.coverage

# Publish output
publish/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Large π-digit data files (add your own locally)
*.pi
pi_digits.txt
