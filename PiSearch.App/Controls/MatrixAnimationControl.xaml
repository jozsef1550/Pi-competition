<UserControl x:Class="PiSearch.App.Controls.MatrixAnimationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF0A0A0A">

    <Grid>
        <!-- Scrolling π-digit rain -->
        <ItemsControl x:Name="DigitColumns"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Detection line -->
        <Rectangle Height="2" VerticalAlignment="Center"
                   Fill="#8039FF14" Margin="0,0,0,0"
                   x:Name="DetectionLine"/>

        <!-- "FOUND" overlay -->
        <Border x:Name="FoundOverlay"
                Background="#CC000000"
                Visibility="Collapsed"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="24,12"
                CornerRadius="8"
                BorderBrush="#FF39FF14"
                BorderThickness="2">
            <StackPanel>
                <TextBlock x:Name="FoundPatternText"
                           FontFamily="Consolas"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FF39FF14"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="FoundIndexText"
                           FontFamily="Consolas"
                           FontSize="14"
                           Foreground="#FFAAFFAA"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
