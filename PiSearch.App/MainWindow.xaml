<Window x:Class="PiSearch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PiSearch.App.ViewModels"
        xmlns:ctrl="clr-namespace:PiSearch.App.Controls"
        mc:Ignorable="d"
        Title="π Search – High-Performance Pi Explorer"
        Height="850" Width="1300"
        MinHeight="650" MinWidth="900"
        Background="{StaticResource DarkBg}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Drawer slide-in / slide-out storyboard -->
        <Storyboard x:Key="DrawerOpenSB">
            <DoubleAnimation Storyboard.TargetName="DrawerColumn"
                             Storyboard.TargetProperty="Width.Value"
                             From="0" To="285"
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="DrawerCloseSB">
            <DoubleAnimation Storyboard.TargetName="DrawerColumn"
                             Storyboard.TargetProperty="Width.Value"
                             From="285" To="0"
                             Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <!-- nothing on load; drawer is toggled via code-behind -->
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="48"/>
            <!-- Search bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════ TITLE BAR ══════════════════════════ -->
        <Border Grid.Row="0" Background="#FF0D0D0D"
                BorderBrush="{StaticResource NeonGreen}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="16,0" VerticalAlignment="Center">
                    <TextBlock Text="π" FontSize="28" Foreground="{StaticResource NeonGreen}"
                               FontFamily="Consolas" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="Pi Search" FontSize="18"
                               Foreground="{StaticResource NeonGreen}"
                               FontFamily="Consolas" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" – High-Performance Explorer"
                               FontSize="13" Foreground="{StaticResource DimText}"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Sampling drawer toggle -->
                <Button Grid.Column="2"
                        Content="⊞  SAMPLING DRAWER"
                        Style="{StaticResource NeonButton}"
                        Command="{Binding ToggleDrawerCommand}"
                        Margin="16,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═════════════════════════ SEARCH BAR ═══════════════════════════ -->
        <Border Grid.Row="1" Background="#FF0F0F0F"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search text input -->
                <TextBox Grid.Row="0" Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource NeonTextBox}"
                         Height="34"
                         ToolTip="Enter text, formula, digits, or symbols (e.g. 1+1=2)"
                         AcceptsReturn="False"
                         Margin="0,0,8,0"/>

                <!-- Encoding selector -->
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="ENCODING" Style="{StaticResource LabelStyle}" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding EncodingMethods}"
                              SelectedItem="{Binding Encoding}"
                              Style="{StaticResource NeonComboBox}"
                              Width="130" Height="34"/>
                </StackPanel>

                <!-- Offset selector -->
                <StackPanel Grid.Row="0" Grid.Column="2"
                            Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="OFFSET" Style="{StaticResource LabelStyle}" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding Offset, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource NeonTextBox}"
                             Width="70" Height="34"
                             ToolTip="Integer offset added to each character code"/>
                </StackPanel>

                <!-- Alternative count -->
                <StackPanel Grid.Row="0" Grid.Column="3"
                            Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="ALTERNATIVES" Style="{StaticResource LabelStyle}" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="-" Style="{StaticResource NeonButton}"
                                Command="{Binding RemoveKeyCommand}"
                                Width="30" Height="34" Padding="0"/>
                        <TextBlock Text="{Binding AlternativeCount}"
                                   Style="{StaticResource ValueStyle}"
                                   VerticalAlignment="Center"
                                   Width="24" TextAlignment="Center"/>
                        <Button Content="+" Style="{StaticResource NeonButton}"
                                Command="{Binding AddKeyCommand}"
                                Width="30" Height="34" Padding="0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Pi file browse -->
                <StackPanel Grid.Row="0" Grid.Column="4"
                            Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="π FILE" Style="{StaticResource LabelStyle}" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding PiFilePath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource NeonTextBox}"
                                 Width="120" Height="34"
                                 ToolTip="Path to π-digit text file (leave blank to use built-in 1000 digits)"/>
                        <Button Content="…" Style="{StaticResource NeonButton}"
                                Command="{Binding BrowsePiFileCommand}"
                                Width="30" Height="34" Padding="0" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Search / Stop buttons -->
                <StackPanel Grid.Row="0" Grid.Column="5"
                            Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="▶  SEARCH"
                            Style="{StaticResource NeonButton}"
                            Command="{Binding StartSearchCommand}"
                            Height="34" Margin="0,0,8,0"
                            Visibility="{Binding IsSearching, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <Button Content="■  STOP"
                            Style="{StaticResource NeonButton}"
                            Command="{Binding StopSearchCommand}"
                            Height="34"
                            BorderBrush="#FFFF3939"
                            Foreground="#FFFF3939"
                            Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- Encoded-pattern preview -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6"
                            Orientation="Horizontal">
                    <TextBlock Text="Encoded: " Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding SearchKeys[0].EncodedPattern}"
                               Style="{StaticResource ValueStyle}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═════════════════════════ MAIN CONTENT ═════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- Matrix animation area -->
                <ColumnDefinition Width="*"/>
                <!-- Sampling drawer (animated width) -->
                <ColumnDefinition x:Name="DrawerColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Matrix animation + results panels -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <!-- Matrix animation (top 55%) -->
                    <RowDefinition Height="3*"/>
                    <!-- Alternative hits (bottom 45%) -->
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <!-- ── Matrix Animation ── -->
                <ctrl:MatrixAnimationControl
                    Grid.Row="0"
                    PiDigitFeed="{Binding SearchKeys[0].EncodedPattern}"
                    FoundIndex="{Binding HighlightIndex}"
                    FoundLength="{Binding HighlightLength}"
                    Margin="0,0,0,1"/>

                <!-- ── Alternative Hits (side-by-side key panels) ── -->
                <Border Grid.Row="1"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Section header -->
                        <Border Grid.Row="0" Background="#0D39FF14" Padding="12,6">
                            <TextBlock Text="ALTERNATIVE HITS  —  RACE VIEW"
                                       Style="{StaticResource ValueStyle}"
                                       FontSize="11"/>
                        </Border>

                        <!-- Key panels -->
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding SearchKeys}"
                                      Margin="8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Single key card -->
                                    <Border Margin="4"
                                            BorderBrush="{Binding IsFound, Converter={StaticResource FoundBrushConverter}}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Background="#FF141414">
                                        <Grid Margin="10,8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Label + encoding -->
                                            <StackPanel Grid.Row="0" Orientation="Horizontal"
                                                        Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Label}"
                                                           Style="{StaticResource ValueStyle}"
                                                           FontSize="11"/>
                                                <TextBlock Text=" | "
                                                           Style="{StaticResource LabelStyle}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding Encoding}"
                                                           Style="{StaticResource LabelStyle}"
                                                           FontSize="11"/>
                                            </StackPanel>

                                            <!-- Encoded pattern preview -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding EncodedPattern}"
                                                       Style="{StaticResource MonoStyle}"
                                                       FontSize="10"
                                                       Foreground="#FF666666"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,6"/>

                                            <!-- Live stats -->
                                            <UniformGrid Grid.Row="2" Rows="3" Columns="2"
                                                         Margin="0,0,0,6">
                                                <TextBlock Text="Index:" Style="{StaticResource LabelStyle}"/>
                                                <TextBlock Text="{Binding CurrentIndex, Converter={StaticResource LargeNumberConverter}}"
                                                           Style="{StaticResource ValueStyle}" FontSize="11"/>

                                                <TextBlock Text="Speed:" Style="{StaticResource LabelStyle}"/>
                                                <TextBlock Text="{Binding Velocity, Converter={StaticResource VelocityConverter}}"
                                                           Style="{StaticResource ValueStyle}" FontSize="11"/>

                                                <TextBlock Text="Prob:" Style="{StaticResource LabelStyle}"/>
                                                <TextBlock Text="{Binding Probability, Converter={StaticResource PercentageConverter}}"
                                                           Style="{StaticResource ValueStyle}" FontSize="11"/>
                                            </UniformGrid>

                                            <!-- Result info -->
                                            <Border Grid.Row="3"
                                                    Background="{Binding IsFound, Converter={StaticResource FoundBrushConverter}}"
                                                    Opacity="0.15"
                                                    CornerRadius="3"/>
                                            <TextBlock Grid.Row="3"
                                                       Text="{Binding ResultInfo}"
                                                       Style="{StaticResource MonoStyle}"
                                                       FontSize="11"
                                                       Foreground="{Binding IsFound, Converter={StaticResource FoundBrushConverter}}"
                                                       TextWrapping="Wrap"
                                                       Padding="4,3"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: Sampling Drawer (slides in/out) -->
            <Border Grid.Column="1"
                    Background="#FF0D0D0D"
                    BorderBrush="{StaticResource NeonGreen}"
                    BorderThickness="1,0,0,0"
                    ClipToBounds="True">
                <ctrl:SamplingDrawer
                    DataContext="{Binding SearchKeys[0].CharacterMap}"
                    VerticalAlignment="Stretch"/>
            </Border>
        </Grid>

        <!-- ═══════════════════════════ STATUS BAR ═════════════════════════ -->
        <Border Grid.Row="3"
                Background="#FF0A0A0A"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource MonoStyle}"
                           VerticalAlignment="Center"
                           FontSize="11"/>

                <!-- Searching spinner -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibility}}">
                    <Ellipse Width="8" Height="8"
                             Fill="{StaticResource NeonGreen}"
                             Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Ellipse.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.1"
                                                                 Duration="0:0:0.6"
                                                                 AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="SEARCHING" Style="{StaticResource ValueStyle}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

