<Application x:Class="PiSearch.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PiSearch.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── Converters ─────────────────────────────────────────────────── -->
        <conv:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <conv:PercentageConverter              x:Key="PercentageConverter"/>
        <conv:LargeNumberConverter             x:Key="LargeNumberConverter"/>
        <conv:VelocityConverter                x:Key="VelocityConverter"/>
        <conv:FoundBrushConverter              x:Key="FoundBrushConverter"/>

        <!-- ── Palette ────────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="DarkBg"      Color="#FF080808"/>
        <SolidColorBrush x:Key="PanelBg"     Color="#FF111111"/>
        <SolidColorBrush x:Key="NeonGreen"   Color="#FF39FF14"/>
        <SolidColorBrush x:Key="DimText"     Color="#FF888888"/>
        <SolidColorBrush x:Key="MidText"     Color="#FFAAAAAA"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FF333333"/>

        <!-- ── Base text styles ───────────────────────────────────────────── -->
        <Style TargetType="TextBlock" x:Key="MonoStyle">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource MidText}"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle" BasedOn="{StaticResource MonoStyle}">
            <Setter Property="Foreground" Value="{StaticResource DimText}"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="ValueStyle" BasedOn="{StaticResource MonoStyle}">
            <Setter Property="Foreground" Value="{StaticResource NeonGreen}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- ── Button style ──────────────────────────────────────────────── -->
        <Style TargetType="Button" x:Key="NeonButton">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderBrush"       Value="{StaticResource NeonGreen}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Foreground"        Value="{StaticResource NeonGreen}"/>
            <Setter Property="FontFamily"        Value="Consolas"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Padding"           Value="12,5"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A39FF14"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TextBox style ─────────────────────────────────────────────── -->
        <Style TargetType="TextBox" x:Key="NeonTextBox">
            <Setter Property="Background"      Value="#FF1A1A1A"/>
            <Setter Property="Foreground"      Value="#FFDDFFDD"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="CaretBrush"      Value="{StaticResource NeonGreen}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource NeonGreen}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ComboBox style ────────────────────────────────────────────── -->
        <Style TargetType="ComboBox" x:Key="NeonComboBox">
            <Setter Property="Background"      Value="#FF1A1A1A"/>
            <Setter Property="Foreground"      Value="#FFDDFFDD"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

    </Application.Resources>
</Application>

